{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "wins": { "type": "integer" },
            "losses": { "type": "integer" },
            "streak": { "type": "integer" },
            "avgGuesses": { "type": "number" },
            "avgTime": { "type": "number" },
            "totalGames": { "type": "integer" }
          }
        }
      },
      "required": ["uid", "username"]
    },
    "Room": {
      "title": "Room",
      "description": "Game room state",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "mode": { "type": "string", "enum": ["1v1", "2v2", "3v3", "coop"] },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "username": { "type": "string" },
              "progress": { "type": "array", "items": { "type": "string" } },
              "isReady": { "type": "boolean" },
              "finished": { "type": "boolean" },
              "guesses": { "type": "integer" },
              "time": { "type": "number" }
            }
          }
        },
        "targetWord": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "winner": { "type": "string" }
      },
      "required": ["roomId", "mode", "difficulty", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Active game rooms"
    }
  }
}
